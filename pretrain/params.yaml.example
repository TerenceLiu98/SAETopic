# Minimal example for the config-driven pretrain pipeline.
#
# This file intentionally keeps only the parameters most users should edit.
# The code still supports advanced tuning keys such as num_proc, buffer_size,
# corpus_adapter_epochs, visual_tokenizer.max_patch_samples, and vLLM knobs.
# Add those only when you are tuning throughput, memory, or ablation settings.
#
# See:
# - docs/pretraining.md
# - docs/vision.md
# - pretrain/README.md

project:
  # Base directory for relative outputs.
  output_dir: /home/jovyan/helloworld-datavol-1/SAETopic
  # Global random seed used by stages that do not define their own seed.
  seed: 42

pipeline:
  # Default text SAE-TM flow. Override with --stages for partial runs.
  # Common vision flow:
  #   [vision_vocab, vision_bow, vision_emission, vision_topics, vision_visualize]
  stages:
    - chunks
    - embeddings
    - train_sae
    - topics
    - evaluate

embedding_model:
  # Hugging Face model used to encode text chunks and images.
  name: jinaai/jina-embeddings-v5-omni-small
  # auto, cuda, cuda:0, cuda:1, cpu.
  device: auto
  # bfloat16 is a good default on recent NVIDIA GPUs; use float16 if needed.
  dtype: bfloat16
  # Must match sae.training.input_dim.
  truncate_dim: 768
  # Maximum tokens per encoded text chunk.
  max_seq_length: 1024
  # Extra kwargs forwarded to Jina encode/document calls.
  model_kwargs:
    default_task: clustering
    modality: text

dataset:
  # "chunks" means embeddings are read from chunks.path after the chunks stage.
  source: chunks
  # Hugging Face dataset used by the chunks stage.
  name: HuggingFaceFW/finewiki
  # Dataset subset/config name. Use null if the dataset has no subset.
  subset: en
  # Dataset split used for pretraining chunks.
  split: train
  # Text field to chunk and encode.
  text_column: text
  # Limit source rows for smoke tests; null means use the full split.
  max_samples: null

chunks:
  # Output dataset directory for chunked text.
  path: /home/jovyan/helloworld-datavol-1/SAETopic/chunks/finewiki_word384
  # Number of words per chunk when using the default word chunker.
  chunk_size: 384
  # Drop very short chunks.
  min_words: 64
  # Continue an interrupted chunking run when possible.
  resume: true
  # Set true only when you want to rebuild chunks from scratch.
  overwrite: false

embeddings:
  # Output directory for sharded embedding arrays.
  path: /home/jovyan/helloworld-datavol-1/SAETopic/embeddings/finewiki_word384_omni_small_embeddings
  # Continue an interrupted embedding run when possible.
  resume: true

sae:
  training:
    # SAE architecture: batch_topk, matryoshka_batch_topk, or ort_batch_topk.
    architecture: batch_topk
    # Embedding dimension consumed by the SAE.
    input_dim: 768
    # Number of SAE features is input_dim * expansion_factor unless n_features is set.
    expansion_factor: 64
    # Active SAE features per sample for TopK-style SAEs.
    top_k: 32
    # Increase this until GPU memory is well used.
    batch_size: 1024
    # Number of passes over the embedding dataset.
    n_epochs: 10
    # Adam learning rate.
    learning_rate: 0.001
    # Checkpoints are saved here.
    output_dir: /home/jovyan/helloworld-datavol-1/SAETopic/checkpoints/jina-v5-omni-small-sae
    # Continue from the latest checkpoint in output_dir when present.
    resume: true

topics:
  # SAE checkpoint to use. null means use sae.training.output_dir.
  checkpoint_path: null
  # Output directory for text topic artifacts and evaluation inputs.
  out_dir: results/text_topics
  # Topic-model datasets. Add more entries for multi-dataset evaluation.
  datasets:
    - key: imdb
      hf_dataset: stanfordnlp/imdb
      hf_split: train+test
      text_column: text
      label_column: label
  # Number of documents per dataset; 0 means all documents.
  n_docs: 0
  # Topic counts to generate.
  n_topics: [50, 100, 200]

evaluation:
  # Paths containing top_words.txt. null means topics.out_dir.
  paths: null
  # JSONL evaluation output.
  out: results/text_topics/saetm_eval_reference.jsonl
  # SAE-TM-compatible word2vec cache for D/CI/CR metrics.
  word_embeddings_dir: /home/jovyan/gensim-data/w2v
  # Optional fallback embedding model if word_embeddings_dir is unavailable.
  embedding_model: null
  # none disables LLM metrics; use vllm for LLM topic rating.
  llm_backend: none
  # LLM used when llm_backend is vllm.
  llm_model: microsoft/phi-4

vision:
  # SAE-TM-style vision flow:
  # image -> DINOv2 patch KMeans BoVW, image -> SAE theta, then learn B_vis.
  # Run with:
  # PYTHONPATH=src python pretrain/run.py --config pretrain/params.yaml \
  #   --stages vision_vocab vision_bow vision_emission vision_topics vision_visualize

  # SAE checkpoint to use. null means use sae.training.output_dir.
  checkpoint_path: null
  # Output directory for visual vocabulary, BoVW, B_vis, topics, and visualizations.
  out_dir: results/vision_topics/flickr8k
  # Hugging Face image dataset.
  hf_dataset: clip-benchmark/wds_flickr8k
  # Dataset subset/config name. Use null if the dataset has no subset.
  hf_subset: null
  # Dataset split.
  hf_split: train
  # Image column name in the dataset.
  image_column: image
  # Optional class/label column. Use null for caption-only datasets.
  label_column: null
  # Limit images for smoke tests; null means use the full split.
  max_samples: null
  # Per-label cap for class-balanced datasets; ignored when label_column is null.
  max_per_label: null
  # Topic counts to generate from visual SAE atoms.
  n_topics: [50, 100, 200]

  visual_tokenizer:
    # Patch feature model used before KMeans visual-word quantization.
    model: facebook/dinov2-base
    # Visual vocabulary size for BoVW.
    codebook_size: 4096

  visualize:
    # Which topic count to visualize.
    n_topics: 50
    # false shows representative full images for each visual word.
    # true reruns DINOv2 assignment and crops representative patches.
    patch_representatives: false
