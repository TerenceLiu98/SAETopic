project:
  output_dir: /home/jovyan/helloworld-datavol-1/SAETopic
  seed: 42

pipeline:
  stages:
    - chunks
    - embeddings
    - train_sae
    - topics
    - evaluate

embedding_model:
  name: jinaai/jina-embeddings-v5-omni-nano
  trust_remote_code: true
  device: auto
  dtype: bfloat16
  truncate_dim: 768
  max_seq_length: 1024
  attn_implementation: null
  model_kwargs:
    default_task: clustering
    modality: text

dataset:
  source: chunks
  chunks_path: /home/jovyan/helloworld-datavol-1/SAETopic/chunks/finewiki_word384
  name: HuggingFaceFW/finewiki
  subset: en
  split: train
  text_column: text
  streaming: false
  buffer_size: 32768
  embedding_batch_size: 2048
  encode_batch_size: 128
  encode_device: auto_multi_cuda
  encode_chunk_size: 128
  num_chunk_workers: 48
  chunk_worker_batch_size: 4096
  prefetch_buffers: 2
  text_split_strategy: word
  min_sentences_per_chunk: 1
  text_chunk_size: 384
  text_chunk_overlap: 0
  normalize: true
  num_proc: 32
  max_samples: null
  task: clustering
  # For Jina omni non-retrieval tasks, the model card recommends document
  # encoding; sanitize_urls prevents FineWiki text links from being treated as
  # image/video/audio/PDF inputs.
  encode_method: document
  sanitize_urls: false

chunks:
  path: /home/jovyan/helloworld-datavol-1/SAETopic/chunks/finewiki_word384
  strategy: word
  chunk_size: 384
  chunk_overlap: 0
  min_words: 64
  sanitize_urls: true
  num_proc: 64
  map_batch_size: 2000
  resume: true
  overwrite: false
  max_source_rows: null

embeddings:
  path: /home/jovyan/helloworld-datavol-1/SAETopic/embeddings/finewiki_word384_omni_embeddings
  chunk_size: 50000
  resume: true

sae:
  normalize_embeddings: false
  mmap_mode: r
  val_fraction: 0.05
  training:
    input_dim: 768
    expansion_factor: 64
    top_k: 32
    architecture: batch_topk
    # For nested multi-granularity dictionaries, use:
    # architecture: matryoshka_batch_topk
    # matryoshka_group_fractions: [0.125, 0.125, 0.25, 0.5]
    # matryoshka_group_weights: null
    # matryoshka_active_groups: null
    # For atomic, decorrelated topic atoms (OrtSAE), use:
    # architecture: ort_batch_topk
    # orthogonality_weight: 0.25
    # orthogonality_chunk_size: 8192
    # orthogonality_freq: 1
    learning_rate: 0.001
    batch_size: 256
    n_epochs: 10
    save_frequency: 1
    # Resume SAE training from an interrupted run.
    resume: true
    resume_from_checkpoint: null
    warmup_ratio: 0.1
    aux_loss_weight: 0.03125
    early_stopping: true
    early_stopping_patience: 2
    early_stopping_min_delta: 0.0001
    early_stopping_metric: val_reconstruction
    device: auto
    seed: 42
    output_dir: /home/jovyan/helloworld-datavol-1/SAETopic/checkpoints/jina-v5-sae-small
    checkpoint_name: jina-v5-sae-small
    dataset_name: HuggingFaceFW/finewiki
    dataset_license: CC-BY-SA 4.0 / Apache 2.0

topics:
  checkpoint_path: null
  out_dir: results/text_topics
  datasets:
    - key: news20k
      source: hf
      hf_dataset: SetFit/20_newsgroups
      hf_split: train+test
      remove_metadata: true
    - key: imdb
      hf_dataset: stanfordnlp/imdb
      hf_split: train+test
      text_column: text
      label_column: label
    - key: yelp
      hf_dataset: Yelp/yelp_review_full
      hf_split: train
      text_column: text
      label_column: label
    - key: dailymail
      hf_dataset: ccdv/cnn_dailymail
      hf_subset: 3.0.0
      hf_split: train
      text_column: article
      label_column: null
  n_docs: 0
  n_topics: [50, 100, 200, 300, 500]
  save_theta_topic: false
  corpus_adapter_epochs: 30
  corpus_adapter_batch_size: 512
  idf_weighting: true
  activation_batch_size: 256
  embedding_batch_size: 64
  vocabulary_size: 5000
  min_df: 5
  max_df: 1.0
  stop_words: saetm
  theta_mode: dense
  max_seq_length: 1024
  use_ctfidf: false
  merge_embedding_model: word2vec-google-news-300
  device: auto

evaluation:
  paths: null
  out: results/text_topics/saetm_eval_reference.jsonl
  word_embeddings_dir: /home/jovyan/gensim-data/w2v
  embedding_model: null
  llm_backend: none
  llm_model: microsoft/phi-4
  max_model_len: 4096
  tensor_parallel_size: 1
  gpu_memory_utilization: 0.9
  max_num_seqs: null
  max_num_batched_tokens: null
  enforce_eager: false
  llm_batch_size: 32
  top_n: 20
  k: 5
  n: 4
  r: 3
  seed: null

vision_probe:
  # Run with:
  # PYTHONPATH=src python pretrain/run.py --config pretrain/params.yaml --stages vision_probe
  checkpoint_path: null
  out_dir: results/vision_probe
  input_file: null
  inputs: []
  # Inline examples:
  # inputs:
  #   - id: car
  #     image: https://huggingface.co/datasets/huggingface/documentation-images/resolve/main/transformers/tasks/car.jpg
  #     label: car
  modality: vision
  task: clustering
  encode_method: document
  batch_size: 8
  activation_batch_size: 128
  top_k: 10
  activation_mode: dense
  normalize: true
  truncate_dim: 768
  device: auto
